# Server
PORT=3001
HOST=0.0.0.0

# Comma-separated frontend URLs allowed by CORS (no trailing slash)
# Local Vite ports 5173/5174 are always allowed by the server code.
# On Render, set your deployed frontend URL, e.g. https://your-app.onrender.com
CORS_ORIGIN=http://localhost:5173,https://your-frontend.example.com

# Loyverse (never commit real values)
LOYVERSE_ACCESS_TOKEN=
LOYVERSE_API_BASE_URL=https://api.loyverse.com/v1.0
# Full catalog cache: max pages per Loyverse list (250 rows/page). 80 ≈ 20,000 items.
LOYVERSE_FULL_MAX_PAGES=80

# MySQL (Hostinger phpMyAdmin) — required for persistent pending requests
# Create database + user in hPanel → Databases → MySQL Databases
# Host is often localhost when API runs ON Hostinger; use Remote MySQL host for local dev
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=your_db_name

# Auth (required when using /api/auth and protected routes)
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
JWT_EXPIRES_IN=7d
# One-time: create first admin when users table is empty (remove or rotate after use)
ADMIN_BOOTSTRAP_SECRET=your-bootstrap-secret
